---
layout: base.njk
title: Contact OnRecord Title | Send Us Your Next Order
description: Contact OnRecord Title for fast title and escrow services in Utah. Call, email, or submit your order online.
breadcrumb:
  - { name: "Contact", url: "/contact/" }
---
<section class="hero hero-inner">
    <div class="container">
        <div class="hero-text">
            <p class="section-label" style="color: var(--color-accent);">Contact</p>
            <h1>Send Us Your Next Order</h1>
            <p class="subheadline">Ready to get started? Reach out and we'll confirm receipt within 1 business hour.</p>
        </div>
    </div>
</section>
<section class="section">
    <div class="container">
        <div class="inner-grid">
            <div>
                <div class="contact-card" style="box-shadow:none; padding:0; max-width:none;">
                    <form action="https://formspree.io/f/placeholder" method="POST">
                        <div class="form-row">
                            <div class="form-group">
                                <label for="name">Your Name</label>
                                <input type="text" id="name" name="name" required>
                            </div>
                            <div class="form-group">
                                <label for="company">Company</label>
                                <input type="text" id="company" name="company">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="email">Email</label>
                                <input type="email" id="email" name="email" required>
                            </div>
                            <div class="form-group">
                                <label for="phone">Phone</label>
                                <input type="tel" id="phone" name="phone">
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="service">Service Needed</label>
                            <select id="service" name="service">
                                <option value="">Select a service...</option>
                                <option value="residential">Residential Closing</option>
                                <option value="commercial">Commercial Transaction</option>
                                <option value="mobile-closing">Mobile Closing</option>
                                <option value="refinance">Refinance</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="message">Project Details</label>
                            <textarea id="message" name="message" rows="5" placeholder="Property address, transaction type, timeline, any special requirements..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg" style="width:100%; justify-content:center;">Send Order</button>
                    </form>
                </div>
            </div>
            <div class="inner-sidebar">
                <div class="sidebar-card">
                    <h3>Contact Info</h3>
                    <ul style="list-style:none; padding:0;">
                        <li style="padding:0.75rem 0; border-bottom:1px solid var(--color-border-light); font-size:0.85rem;">
                            <strong>Phone</strong><br>
                            <a href="tel:{{ site.phone }}" style="color: var(--color-secondary); text-decoration:none;">{{ site.phone }}</a>
                        </li>
                        <li style="padding:0.75rem 0; border-bottom:1px solid var(--color-border-light); font-size:0.85rem;">
                            <strong>Email</strong><br>
                            <a href="mailto:{{ site.email }}" style="color: var(--color-secondary); text-decoration:none;">{{ site.email }}</a>
                        </li>
                        <li style="padding:0.75rem 0; border-bottom:1px solid var(--color-border-light); font-size:0.85rem;">
                            <strong>Address</strong><br>
                            {{ site.address.street }}<br>
                            {{ site.address.city }}, {{ site.address.state }} {{ site.address.zip }}
                        </li>
                        <li style="padding:0.75rem 0; font-size:0.85rem;">
                            <strong>Hours</strong><br>
                            {{ site.hours }}
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
