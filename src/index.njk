<!-- FAQ -->
<section class="section section-light">
    <div class="container">
        <div class="section-header">
            <p class="section-label">Common Questions</p>
            <h2>Frequently Asked Questions</h2>
        </div>
        <div class="faq-list">
            <details class="faq-item">
                <summary>What does a title company actually do?</summary>
                <div class="faq-answer">
                    <p>A title company searches public records to verify property ownership, identifies any liens or encumbrances, issues title insurance to protect buyers and lenders, and handles the escrow process — holding funds and documents until all conditions are met for closing.</p>
                </div>
            </details>
            <details class="faq-item">
                <summary>How fast can you deliver a title commitment?</summary>
                <div class="faq-answer">
                    <p>We typically deliver title commitments within 2 business days — significantly faster than the industry average of 5-7 days. For rush orders, contact us directly and we'll do everything we can to accommodate your timeline.</p>
                </div>
            </details>
            <details class="faq-item">
                <summary>What areas do you serve?</summary>
                <div class="faq-answer">
                    <p>We serve the entire state of Utah with a focus on the Wasatch Front — Salt Lake City, Provo/Orem, Ogden, Park City, and surrounding communities. Our mobile closing service extends our reach to wherever your clients need us.</p>
                </div>
            </details>
            <details class="faq-item">
                <summary>Do you offer volume pricing for agents and brokers?</summary>
                <div class="faq-answer">
                    <p>Yes. We offer competitive volume pricing for real estate professionals who consistently send business our way. The more you work with us, the better your rates. Contact us to discuss a volume arrangement.</p>
                </div>
            </details>
            <details class="faq-item">
                <summary>What is a mobile closing?</summary>
                <div class="faq-answer">
                    <p>A mobile closing means we send a licensed escrow officer to a location of your choice — your office, the buyer's home, a hospital, wherever is most convenient. Same professional service, just more flexible on location.</p>
                </div>
            </details>
            <details class="faq-item">
                <summary>How do I send you a new order?</summary>
                <div class="faq-answer">
                    <p>Email us at <a href="mailto:{{ site.email }}">{{ site.email }}</a>, call us at <a href="tel:{{ site.phone }}">{{ site.phone }}</a>, or use our <a href="/contact/">online form</a>. Just send the purchase contract and we'll handle the rest. We confirm receipt within 1 business hour.</p>
                </div>
            </details>
        </div>
    </div>
</section>

<!-- Contact CTA -->
<section class="home-contact">
    <div class="container">
        <div class="contact-card">
            <div class="section-header" style="margin-bottom:2rem;">
                <h2>Ready to Send Your Next Order?</h2>
                <p style="color: var(--color-text-body);">Get in touch and experience the difference a responsive title company makes.</p>
            </div>
            <form action="https://formspree.io/f/placeholder" method="POST">
                <div class="form-row">
                    <div class="form-group">
                        <label for="name">Your Name</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="company">Company</label>
                        <input type="text" id="company" name="company">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" required>
                    </div>
                    <div class="form-group">
                        <label for="phone">Phone</label>
                        <input type="tel" id="phone" name="phone">
                    </div>
                </div>
                <div class="form-group">
                    <label for="message">Project Details</label>
                    <textarea id="message" name="message" rows="4" placeholder="Property address, transaction type, timeline..."></textarea>
                </div>
                <button type="submit" class="btn btn-primary btn-lg" style="width:100%; justify-content:center;">Send Order</button>
            </form>
        </div>
    </div>
</section>
